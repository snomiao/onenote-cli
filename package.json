{
  "name": "onenote-cli",
  "version": "0.1.0",
  "description": "Make your OneNote notebooks survive in the age of AI",
  "type": "module",
  "bin": {
    "onenote-cli": "./src/index.ts",
    "onenote": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "bunx tsgo --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxlint --fix"
    ],
    "**/*": "secretlint"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.0",
    "@types/react": "^19.2.14",
    "ink": "^7.0.1",
    "pretty-bytes": "^7.1.0",
    "react": "^19.2.5",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^11.6.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/bun": "^1.3.12",
    "@types/yargs": "^17.0.33",
    "@typescript/native-preview": "^7.0.0-dev.20260412.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.59.0",
    "secretlint": "^11.6.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
